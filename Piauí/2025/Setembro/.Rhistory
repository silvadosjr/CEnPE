geom_point(aes(color = Modelo), alpha = 0.9, size = 2) +
facet_wrap(~ Modelo, nrow = 1) +
coord_equal(xlim = c(0,1), ylim = c(0,1), expand = TRUE) +
labs(
title = "Comparação pontual: Kaplan–Meier vs. Modelos Paramétricos",
x = expression(hat(S)(t)~" (Kaplan–Meier)"),
y = expression(S[modelo](t))
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "none",
strip.text = element_text(face = "bold"),
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
print(p_panel)
# ===== Tempos e S(t) do Kaplan–Meier (nos pontos de salto) =====
df_km <- data.frame(t = km_fit$time, KM = km_fit$surv)
# ===== S(t) dos modelos nos MESMOS tempos do KM =====
S_exp <- get_surv(exp_fit, df_km$t)
S_wei <- get_surv(wei_fit, df_km$t)
S_ln  <- get_surv(ln_fit,  df_km$t)
df_compare <- df_km |>
mutate(Exponencial = S_exp, Weibull = S_wei, `Log-normal` = S_ln) |>
pivot_longer(cols = c("Exponencial","Weibull","Log-normal"),
names_to = "Modelo", values_to = "S_modelo")
# ===== Painel de dispersão: y = S_modelo, x = KM =====
p_panel <- ggplot(df_compare, aes(x = KM, y = S_modelo)) +
geom_abline(slope = 1, intercept = 0, linewidth = 0.8, linetype = "dashed", color = "grey40") +
geom_point(aes(color = Modelo), alpha = 0.9, size = 2) +
facet_wrap(~ Modelo, nrow = 1) +
coord_equal(xlim = c(0,1), ylim = c(0,1), expand = TRUE) +
labs(
title = "Comparação pontual: Kaplan–Meier vs. Modelos Paramétricos",
x = expression(hat(S)(t)~" (Kaplan–Meier)"),
y = expression(S[modelo](t))
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "none",
strip.text = element_text(face = "bold"),
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
print(p_panel)
# ===== Painel de dispersão: y = S_modelo, x = KM =====
p_panel <- ggplot(df_compare, aes(x = KM, y = S_modelo)) +
geom_abline(slope = 1, intercept = 0, linewidth = 0.8, linetype = "dashed", color = "grey40") +
geom_point(aes(color = Modelo), alpha = 0.9, size = 2) +
facet_wrap(~ Modelo, nrow = 1) +
coord_equal(xlim = c(0,1), ylim = c(0,1), expand = TRUE) +
labs(
title = "",
x = expression(hat(S)(t)~" (Kaplan–Meier)"),
y = expression(S[modelo](t))
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "none",
strip.text = element_text(face = "bold"),
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
print(p_panel)
# ===== Salvar figura =====
ggsave(filename = file.path(fig_dir, "Painel_KM_vs_Modelos.png"), plot = p, width = 8, height = 5, dpi = 300)
cat("\nFigura salva em:", fig_dir, "\n")
# ===== Salvar figura =====
ggsave(filename = file.path(fig_dir, "Painel_KM_vs_Modelos.png"), plot = p_panel, width = 8, height = 5, dpi = 300)
# Pontos de KM (apenas onde S(t) está estritamente entre 0 e 1)
df_km <- data.frame(t = km_fit$time, S = km_fit$surv) |>
filter(S > 0 & S < 1)
# Transformações para linearização
df_lin <- bind_rows(
transmute(df_km,
Modelo = "Exponencial",
x = t,
y = -log(S)),
transmute(df_km,
Modelo = "Weibull",
x = log(t),
y = log(-log(S))),
transmute(df_km,
Modelo = "Log-normal",
x = log(t),
y = qnorm(1 - S)) # Phi^{-1}[1 - S(t)]
)
# Rótulos dos eixos por painel
axis_labs <- data.frame(
Modelo = c("Exponencial","Weibull","Log-normal"),
xlab   = c("Tempo (t)", "log(Tempo)", "log(Tempo)"),
ylab   = c(expression(-log(S(t))),
expression(log(-log(S(t)))),
expression(Phi^{-1}(1 - S(t))))
)
axis_labs
# Rótulos dos eixos por painel
axis_labs <- data.frame(
Modelo = c("Exponencial","Weibull","Log-normal"),
xlab   = c("Tempo (t)", "log(Tempo)", "log(Tempo)"),
ylab   = c(expression(-log(S(t))),
